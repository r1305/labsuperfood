<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <!-- Topbar -->
    <div class="app-topbar">
        <a href="/" class="brand">
            <div class="brand-icon"><i class="fas fa-file-invoice-dollar"></i></div>
            <span class="d-none d-sm-inline">Cotizaciones</span>
        </a>
        <!-- Tabs desktop -->
        <ul class="nav nav-tabs d-none d-md-flex" id="adminTabsDesktop" role="tablist" style="border:none; margin-bottom:-1px;">
            <li class="nav-item"><button class="nav-link active" id="cotizacion-tab" data-bs-toggle="tab" data-bs-target="#cotizacion" type="button"><i class="fas fa-plus-circle"></i> Nueva Cotización</button></li>
            <li class="nav-item"><button class="nav-link" id="lista-cotizaciones-tab" data-bs-toggle="tab" data-bs-target="#lista-cotizaciones" type="button"><i class="fas fa-list"></i> Cotizaciones</button></li>
            <li class="nav-item"><button class="nav-link" id="productos-tab" data-bs-toggle="tab" data-bs-target="#productos" type="button"><i class="fas fa-box"></i> Productos</button></li>
            <li class="nav-item"><button class="nav-link" id="clientes-tab" data-bs-toggle="tab" data-bs-target="#clientes" type="button"><i class="fas fa-users"></i> Clientes</button></li>
            <li class="nav-item"><button class="nav-link" id="configuracion-tab" data-bs-toggle="tab" data-bs-target="#configuracion" type="button"><i class="fas fa-cog"></i> Config</button></li>
            <li class="nav-item"><button class="nav-link" id="company-tab" data-bs-toggle="tab" data-bs-target="#company" type="button"><i class="fas fa-building"></i> Compañía</button></li>
        </ul>
        <span class="d-none d-md-inline" style="font-size:12px; color:var(--text-muted);"><i class="fas fa-circle" style="color:#22c55e; font-size:8px;"></i> Activo</span>
    </div>

    <div class="container-fluid px-2 px-md-3 py-2 py-md-3" style="padding-bottom: 80px;">
        <div class="tab-content" id="adminTabsContent">
            <!-- Tab Cotización -->
            <div class="tab-pane fade show active" id="cotizacion" role="tabpanel">
                <div class="row mt-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5 class="mb-0"><i class="fas fa-plus-circle"></i> Nueva Cotización</h5>
                            </div>
                            <div class="card-body">
                                <!-- Selección de Cliente -->
                                <div class="row mb-3">
                                    <div class="col-lg-4 col-md-6 col-12 mb-3">
                                        <label class="form-label"><i class="fas fa-building"></i> Compañía</label>
                                        <select class="form-select" id="selectCompanyCotizacion">
                                            <option value="1">Cargando...</option>
                                        </select>
                                    </div>
                                    <div class="col-lg-4 col-md-6 col-12 mb-3">
                                        <label class="form-label"><i class="fas fa-search"></i> Buscar Cliente</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="buscarClienteCotizacion" placeholder="Buscar por razón social, DNI/RUC...">
                                            <button class="btn btn-outline-secondary" type="button" id="btnLimpiarCliente">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                        <select class="form-select mt-2" id="selectCliente" size="4" style="display:none;">
                                        </select>
                                    </div>
                                    <div class="col-lg-4 col-md-12">
                                        <div id="datosClienteSeleccionado" class="cliente-info" style="display:none;">
                                            <h6><i class="fas fa-user-check"></i> Cliente Seleccionado:</h6>
                                            <div id="infoCliente"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Agregar Productos -->
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <h6><i class="fas fa-box"></i> Agregar Productos</h6>
                                        <div class="row g-2">
                                            <div class="col-lg-3 col-md-6 col-12">
                                                <label class="form-label">Buscar Producto</label>
                                                <input type="text" class="form-control" id="buscarProductoCotizacion" placeholder="Buscar producto...">
                                                <select class="form-select mt-2" id="selectProducto" size="3" style="display:none;">
                                                </select>
                                            </div>
                                            <div class="col-lg-2 col-md-6 col-12" id="colTipoPrecio" style="display:none;">
                                                <label class="form-label">Tipo de Precio</label>
                                                <select class="form-select" id="selectTipoPrecio">
                                                    <option value="">-- Seleccionar tipo --</option>
                                                </select>
                                            </div>
                                            <div class="col-lg-2 col-md-3 col-6">
                                                <label class="form-label">Precio</label>
                                                <input type="number" step="0.01" min="0" class="form-control" id="precioProductoSeleccionado" placeholder="0.00">
                                            </div>
                                            <div class="col-lg-1 col-md-3 col-6">
                                                <label class="form-label">Desc. %</label>
                                                <div class="input-group">
                                                    <input type="number" step="0.01" min="0" max="100" class="form-control" id="descuentoProducto" placeholder="0" value="0">
                                                    <span class="input-group-text">%</span>
                                                </div>
                                            </div>
                                            <div class="col-lg-2 col-md-3 col-6">
                                                <label class="form-label">Cantidad</label>
                                                <input type="number" step="1" min="1" class="form-control" id="cantidadProducto" placeholder="0">
                                            </div>
                                            <div class="col-lg-2 col-md-6 col-12">
                                                <label class="form-label">Total</label>
                                                <input type="text" class="form-control" id="totalProducto" readonly>
                                            </div>
                                            <div class="col-lg-3 col-md-6 col-12">
                                                <label class="form-label d-none d-md-block">&nbsp;</label>
                                                <button type="button" class="btn btn-primary d-block w-100 touch-friendly" id="btnAgregarItem">
                                                    <i class="fas fa-plus"></i> Agregar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Lista de Items -->
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <h6><i class="fas fa-list"></i> Items de la Cotización</h6>
                                        <div class="table-responsive mobile-scroll">
                                            <table class="table table-bordered table-sm">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width: 30%; min-width: 150px;">Producto</th>
                                                        <th style="width: 13%; text-align: center; min-width: 80px;">Precio Unit.</th>
                                                        <th style="width: 10%; text-align: center; min-width: 60px;">Desc. %</th>
                                                        <th style="width: 10%; text-align: center; min-width: 70px;">Cantidad</th>
                                                        <th style="width: 13%; text-align: center; min-width: 80px;">Total</th>
                                                        <th style="width: 13%; text-align: center; min-width: 80px;">Por Facturar</th>
                                                        <th style="width: 8%; text-align: center; min-width: 60px;">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="itemsCotizacion">
                                                    <tr id="noItems">
                                                        <td colspan="6" class="text-center text-muted">No hay items agregados</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Totales -->
                                <div class="row">
                                    <div class="col-lg-6 offset-lg-6 col-md-8 offset-md-4 col-12">
                                        <div class="card totales-mobile">
                                            <div class="card-body">
                                                <div class="row mb-2">
                                                    <div class="col-7"><strong>Total a Pagar:</strong></div>
                                                    <div class="col-5 text-end"><strong id="totalAPagar">S/ 0.00</strong></div>
                                                </div>
                                                <div class="row mb-2">
                                                    <div class="col-7"><strong>Por Facturar:</strong></div>
                                                    <div class="col-5 text-end"><strong id="totalPorFacturar">S/ 0.00</strong></div>
                                                </div>
                                                <div class="row mb-2">
                                                    <div class="col-7">Abono:</div>
                                                    <div class="col-5">
                                                        <input type="number" step="0.01" min="0" class="form-control form-control-sm" id="abono" placeholder="0.00" value="0">
                                                    </div>
                                                </div>
                                                <hr>
                                                <div class="row mb-3">
                                                    <div class="col-7"><strong>Saldo:</strong></div>
                                                    <div class="col-5 text-end"><strong id="saldo">S/ 0.00</strong></div>
                                                </div>
                                                <div class="d-grid">
                                                    <button type="button" class="btn btn-success btn-lg touch-friendly" id="btnGuardarCotizacion">
                                                        <i class="fas fa-save"></i> Guardar Cotización
                                                    </button>
                                                </div>
                                                
                                                <!-- Información Bancaria -->
                                                <div class="mt-3" id="infoBancaria" style="display:none;">
                                                    <h6 class="text-primary"><i class="fas fa-university"></i> Información para Depósito</h6>
                                                    <div id="cuentasBancariasInfo"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Lista de Cotizaciones -->
            <div class="tab-pane fade" id="lista-cotizaciones" role="tabpanel">
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5>Lista de Cotizaciones</h5>
                                <button class="btn btn-primary btn-sm" onclick="cargarCotizaciones()">
                                    <i class="fas fa-sync"></i> Actualizar
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <input type="text" class="form-control" id="buscarCotizacion" placeholder="Buscar por cliente...">
                                    </div>
                                    <div class="col-md-3">
                                        <select class="form-select" id="filtroEstado">
                                            <option value="">Todos los estados</option>
                                            <option value="pendiente">Pendiente</option>
                                            <option value="pagado">Pagado</option>
                                            <option value="cancelado">Cancelado</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="table-responsive mobile-scroll">
                                    <table class="table table-hover table-sm">
                                        <thead class="table-light">
                                            <tr>
                                                <th class="text-center" style="min-width: 60px;">ID</th>
                                                <th style="min-width: 150px;">Cliente</th>
                                                <th class="text-center" style="min-width: 80px;">Total</th>
                                                <th class="text-center" style="min-width: 70px;">Abono</th>
                                                <th class="text-center" style="min-width: 70px;">Saldo</th>
                                                <th class="text-center" style="min-width: 80px;">Estado</th>
                                                <th class="text-center" style="min-width: 90px;">Fecha</th>
                                                <th class="text-center" style="min-width: 120px;">Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tablaCotizaciones">
                                            <tr id="noCotizaciones">
                                                <td colspan="8" class="text-center text-muted">No hay cotizaciones registradas</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Productos -->
            <div class="tab-pane fade" id="productos" role="tabpanel">
                <div class="row mt-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="fas fa-box"></i> Productos <span class="badge bg-light text-dark ms-2" id="contadorProductos">0</span></h5>
                                <button class="btn btn-light btn-sm" onclick="abrirModalProducto()">
                                    <i class="fas fa-plus"></i> Nuevo Producto
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" id="buscarProducto" placeholder="Buscar producto...">
                                    </div>
                                </div>
                                <div id="listaProductos"></div>
                                <div id="paginacionProductos" class="d-flex justify-content-between align-items-center mt-3"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal Producto -->
            <!-- Modal Clientes y Etiquetas se mueven fuera del tab-content -->
            <div class="tab-pane fade" id="clientes" role="tabpanel">
                <div class="row mt-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="fas fa-users"></i> Clientes <span class="badge bg-light text-dark ms-2" id="contadorClientes">0</span></h5>
                                <button class="btn btn-light btn-sm" onclick="abrirModalCliente()">
                                    <i class="fas fa-plus"></i> Nuevo Cliente
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" id="buscarCliente" placeholder="Buscar por nombre, DNI/RUC, distrito...">
                                    </div>
                                </div>
                                <div id="listaClientes"></div>
                                <div id="paginacionClientes" class="d-flex justify-content-between align-items-center mt-3"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal Etiquetas Cliente -->
            <!-- Modal Cliente se mueven fuera del tab-content -->
            <div class="tab-pane fade" id="company" role="tabpanel">
                <div class="row mt-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="fas fa-building"></i> Compañías <span class="badge bg-light text-dark ms-2" id="contadorCompany">0</span></h5>
                                <button class="btn btn-light btn-sm" onclick="abrirModalCompany()">
                                    <i class="fas fa-plus"></i> Nueva Compañía
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" id="buscarCompany" placeholder="Buscar por razón social o RUC/DNI...">
                                    </div>
                                </div>
                                <div id="listaCompany"></div>
                                <div id="paginacionCompany" class="d-flex justify-content-between align-items-center mt-3"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="configuracion" role="tabpanel">
                <div class="row mt-3">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="mb-0"><i class="fas fa-university"></i> Cuentas Bancarias <span class="badge bg-light text-dark ms-2" id="contadorBancos">0</span></h5>
                                <button class="btn btn-light btn-sm" onclick="abrirModalBanco()">
                                    <i class="fas fa-plus"></i> Nueva Cuenta
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" id="buscarBanco" placeholder="Buscar por banco, titular, cuenta...">
                                    </div>
                                </div>
                                <div id="listaCuentasBancarias"></div>
                                <div id="paginacionBancos" class="d-flex justify-content-between align-items-center mt-3"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Tipos de Precio -->
    <div class="modal fade" id="modalTiposPrecio" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-tags"></i> Tipos de Precio: <span id="nombreProductoTipos"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="mb-3"><i class="fas fa-plus-circle"></i> Nuevo Tipo de Precio</h6>
                            <div class="row g-2 align-items-end">
                                <div class="col-md-6 col-12">
                                    <label class="form-label">Tipo</label>
                                    <input type="text" class="form-control" id="inputTipoPrecio"
                                        placeholder="Ej: Mayorista, Minorista, VIP...">
                                </div>
                                <div class="col-md-4 col-8">
                                    <label class="form-label">Precio</label>
                                    <div class="input-group">
                                        <span class="input-group-text">S/</span>
                                        <input type="number" step="0.01" min="0" class="form-control"
                                            id="inputPrecioTipo" placeholder="0.00">
                                    </div>
                                </div>
                                <div class="col-md-2 col-4">
                                    <button class="btn btn-primary w-100" onclick="agregarTipoPrecio()">
                                        <i class="fas fa-plus"></i> Agregar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="listaTiposPrecio"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Producto -->
    <div class="modal fade" id="modalProducto" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="tituloModalProducto"><i class="fas fa-plus-circle"></i> Nuevo Producto</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formProducto">
                        <input type="hidden" id="productoId" name="id">
                        <div class="mb-3">
                            <label class="form-label">Compañía</label>
                            <select class="form-select" id="productoCompanyId" name="company_id" required>
                                <option value="1">Cargando...</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="nombreProducto" class="form-label">Nombre del Producto</label>
                            <input type="text" class="form-control" id="nombreProducto" name="nombre"
                                placeholder="Ej: Proteína Whey 1kg" required>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" id="btnGuardarProducto">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Cliente -->
    <div class="modal fade" id="modalCliente" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="tituloModalCliente"><i class="fas fa-user-plus"></i> Nuevo Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formCliente">
                        <input type="hidden" id="clienteId" name="id">
                        <div class="mb-3">
                            <label class="form-label">Compañía</label>
                            <select class="form-select" id="clienteCompanyId" name="company_id" required>
                                <option value="1">Cargando...</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="razonSocial" class="form-label">Razón Social</label>
                            <input type="text" class="form-control" id="razonSocial" name="razon_social"
                                placeholder="Ej: Empresa SAC" required>
                        </div>
                        <div class="mb-3">
                            <label for="dniRuc" class="form-label">DNI / RUC</label>
                            <input type="text" class="form-control" id="dniRuc" name="dni_ruc"
                                placeholder="Ej: 20123456789" required>
                        </div>
                        <div class="mb-3">
                            <label for="distrito" class="form-label">Distrito</label>
                            <input type="text" class="form-control" id="distrito" name="distrito"
                                placeholder="Ej: Miraflores" required>
                        </div>
                        <div class="mb-3">
                            <label for="direccion" class="form-label">Dirección</label>
                            <input type="text" class="form-control" id="direccion" name="direccion"
                                placeholder="Ej: Av. Principal 123" required>
                        </div>
                        <div class="mb-3">
                            <label for="telefono" class="form-label">Teléfono</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-phone"></i></span>
                                <input type="text" class="form-control" id="telefono" name="telefono"
                                    placeholder="Ej: 987654321" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="correoCliente" class="form-label">Correo Electrónico</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="fas fa-envelope"></i></span>
                                <input type="email" class="form-control" id="correoCliente" name="correo"
                                    placeholder="Ej: contacto@empresa.com">
                            </div>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" id="btnGuardarCliente">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Etiquetas Cliente -->
    <div class="modal fade" id="modalEtiquetas" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="fas fa-tags"></i> Etiquetas de <span id="nombreClienteEtiquetas"></span></h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="card mb-3">
                        <div class="card-body">
                            <h6 class="mb-3"><i class="fas fa-plus-circle"></i> Nueva Etiqueta</h6>
                            <div class="row g-2">
                                <div class="col-md-5 col-12">
                                    <label class="form-label">Marca</label>
                                    <input type="text" class="form-control" id="inputMarca" placeholder="Ej: Nike, Adidas...">
                                </div>
                                <div class="col-md-5 col-12">
                                    <label class="form-label">Nombre del Producto</label>
                                    <input type="text" class="form-control" id="inputNombreProductoEtiqueta" placeholder="Ej: Zapatillas Air Max...">
                                </div>
                                <div class="col-md-12 col-12">
                                    <label class="form-label">Foto</label>
                                    <input type="file" class="form-control" id="inputFotoEtiqueta" accept="image/*">
                                </div>
                                <div class="col-12">
                                    <button class="btn btn-primary w-100" onclick="agregarEtiqueta()">
                                        <i class="fas fa-plus"></i> Agregar Etiqueta
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div id="listaEtiquetasCliente"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Banco -->
    <div class="modal fade" id="modalBanco" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="tituloModalBanco"><i class="fas fa-university"></i> Nueva Cuenta Bancaria</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formBanco">
                        <input type="hidden" id="bancoId" name="id">
                        <div class="mb-3">
                            <label class="form-label">Compañía</label>
                            <select class="form-select" id="bancoCompanyId" name="company_id" required>
                                <option value="1">Cargando...</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="nombreBanco" class="form-label">Banco</label>
                            <select class="form-select" id="nombreBanco" name="banco" required>
                                <option value="">Seleccionar banco...</option>
                                <option value="BCP">Banco de Crédito del Perú (BCP)</option>
                                <option value="BBVA">BBVA</option>
                                <option value="Scotiabank">Scotiabank</option>
                                <option value="Interbank">Interbank</option>
                                <option value="Banco de la Nación">Banco de la Nación</option>
                                <option value="Banbif">Banbif</option>
                                <option value="Pichincha">Banco Pichincha</option>
                                <option value="Falabella">Banco Falabella</option>
                                <option value="Ripley">Banco Ripley</option>
                                <option value="Otro">Otro</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="tipoCuenta" class="form-label">Tipo de Cuenta</label>
                            <select class="form-select" id="tipoCuenta" name="tipo_cuenta" required>
                                <option value="">Seleccionar tipo...</option>
                                <option value="ahorros">Cuenta de Ahorros</option>
                                <option value="corriente">Cuenta Corriente</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="numeroCuenta" class="form-label">Número de Cuenta</label>
                            <input type="text" class="form-control" id="numeroCuenta" name="numero_cuenta" required>
                        </div>
                        <div class="mb-3">
                            <label for="cci" class="form-label">CCI (Opcional)</label>
                            <input type="text" class="form-control" id="cci" name="cci" placeholder="Código de Cuenta Interbancario">
                        </div>
                        <div class="mb-3">
                            <label for="titular" class="form-label">Titular de la Cuenta</label>
                            <input type="text" class="form-control" id="titular" name="titular" required>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" id="btnGuardarBanco">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Compañía -->
    <div class="modal fade" id="modalCompany" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="tituloModalCompany"><i class="fas fa-building"></i> Nueva Compañía</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="formCompany">
                        <input type="hidden" id="companyId" name="id">
                        <div class="mb-3">
                            <label class="form-label">Razón Social</label>
                            <input type="text" class="form-control" id="companyRazonSocial" name="razon_social"
                                placeholder="Ej: Mi Empresa S.A.C" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">RUC / DNI</label>
                            <input type="text" class="form-control" id="companyRucDni" name="ruc_dni"
                                placeholder="Ej: 20123456789" required>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                        <i class="fas fa-times"></i> Cancelar
                    </button>
                    <button type="button" class="btn btn-primary" id="btnGuardarCompany">
                        <i class="fas fa-save"></i> Guardar
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/admin.js"></script>

    <!-- Bottom Navigation (solo móvil) -->
    <nav class="bottom-nav d-md-none">
        <button class="bottom-nav-item active" onclick="activarTab('cotizacion', this)">
            <i class="fas fa-plus-circle"></i>
            <span>Nueva</span>
        </button>
        <button class="bottom-nav-item" onclick="activarTab('lista-cotizaciones', this)">
            <i class="fas fa-list"></i>
            <span>Cotizaciones</span>
        </button>
        <button class="bottom-nav-item" onclick="activarTab('productos', this)">
            <i class="fas fa-box"></i>
            <span>Productos</span>
        </button>
        <button class="bottom-nav-item" onclick="activarTab('clientes', this)">
            <i class="fas fa-users"></i>
            <span>Clientes</span>
        </button>
        <button class="bottom-nav-item" onclick="activarTab('configuracion', this)">
            <i class="fas fa-ellipsis-h"></i>
            <span>Más</span>
        </button>
    </nav>

    <script>
    function activarTab(tabId, btn) {
        // Usar el trigger del desktop para activar el tab via Bootstrap
        const trigger = document.querySelector('#adminTabsDesktop [data-bs-target="#' + tabId + '"]');
        if (trigger) {
            bootstrap.Tab.getOrCreateInstance(trigger).show();
        }
        // Actualizar bottom nav
        document.querySelectorAll('.bottom-nav-item').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }
    // Sincronizar bottom nav cuando se hace clic en desktop
    document.addEventListener('DOMContentLoaded', function() {
        const tabMap = {
            'cotizacion': 0,
            'lista-cotizaciones': 1,
            'productos': 2,
            'clientes': 3,
            'configuracion': 4
        };
        document.querySelectorAll('#adminTabsDesktop .nav-link').forEach(tab => {
            tab.addEventListener('shown.bs.tab', function() {
                const target = this.getAttribute('data-bs-target').replace('#', '');
                const idx = tabMap[target];
                const btns = document.querySelectorAll('.bottom-nav-item');
                btns.forEach((b, i) => b.classList.toggle('active', i === idx));
            });
        });
    });
    </script>
</body>
</html>