<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <div class="container mt-4">
        <h1 class="text-center mb-4">Panel de Administración - LabSuperFood</h1>
        
        <ul class="nav nav-tabs" id="adminTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="cotizacion-tab" data-bs-toggle="tab" data-bs-target="#cotizacion" type="button" role="tab">
                    Nueva Cotización
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="lista-cotizaciones-tab" data-bs-toggle="tab" data-bs-target="#lista-cotizaciones" type="button" role="tab">
                    Cotizaciones
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="productos-tab" data-bs-toggle="tab" data-bs-target="#productos" type="button" role="tab">
                    Productos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="clientes-tab" data-bs-toggle="tab" data-bs-target="#clientes" type="button" role="tab">
                    Clientes
                </button>
            </li>
        </ul>

        <div class="tab-content" id="adminTabsContent">
            <!-- Tab Cotización -->
            <div class="tab-pane fade show active" id="cotizacion" role="tabpanel">
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header">
                                <h5>Nueva Cotización</h5>
                            </div>
                            <div class="card-body">
                                <!-- Selección de Cliente -->
                                <div class="row mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label">Buscar Cliente</label>
                                        <div class="input-group">
                                            <input type="text" class="form-control" id="buscarClienteCotizacion" placeholder="Buscar por razón social, DNI/RUC...">
                                            <button class="btn btn-outline-secondary" type="button" id="btnLimpiarCliente">
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                        <select class="form-select mt-2" id="selectCliente" size="5" style="display:none;">
                                        </select>
                                    </div>
                                    <div class="col-md-6">
                                        <div id="datosClienteSeleccionado" class="cliente-info" style="display:none;">
                                            <h6>Cliente Seleccionado:</h6>
                                            <div id="infoCliente"></div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Agregar Productos -->
                                <div class="row mb-4">
                                    <div class="col-12">
                                        <h6>Agregar Productos</h6>
                                        <div class="row">
                                            <div class="col-md-4">
                                                <label class="form-label">Buscar Producto</label>
                                                <input type="text" class="form-control" id="buscarProductoCotizacion" placeholder="Buscar producto...">
                                                <select class="form-select mt-2" id="selectProducto" size="4" style="display:none;">
                                                </select>
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Precio</label>
                                                <input type="number" step="0.01" min="0" class="form-control" id="precioProductoSeleccionado" placeholder="0.00">
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Cantidad</label>
                                                <input type="number" step="0.01" min="0" class="form-control" id="cantidadProducto" placeholder="0.00">
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">Total</label>
                                                <input type="text" class="form-control" id="totalProducto" readonly>
                                            </div>
                                            <div class="col-md-2">
                                                <label class="form-label">&nbsp;</label>
                                                <button type="button" class="btn btn-primary d-block w-100" id="btnAgregarItem">
                                                    <i class="fas fa-plus"></i> Agregar
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Lista de Items -->
                                <div class="row mb-4">
                                    <div class="col-12">
                                        <h6>Items de la Cotización</h6>
                                        <div class="table-responsive">
                                            <table class="table table-bordered table-sm">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th style="width: 40%;">Producto</th>
                                                        <th style="width: 15%; text-align: center;">Precio Unit.</th>
                                                        <th style="width: 12%; text-align: center;">Cantidad</th>
                                                        <th style="width: 15%; text-align: center;">Total</th>
                                                        <th style="width: 15%; text-align: center;">Por Facturar</th>
                                                        <th style="width: 8%; text-align: center;">Acciones</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="itemsCotizacion">
                                                    <tr id="noItems">
                                                        <td colspan="6" class="text-center text-muted">No hay items agregados</td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>

                                <!-- Totales -->
                                <div class="row">
                                    <div class="col-md-6 offset-md-6">
                                        <div class="card">
                                            <div class="card-body">
                                                <div class="row mb-2">
                                                    <div class="col-6"><strong>Total a Pagar:</strong></div>
                                                    <div class="col-6 text-end"><strong id="totalAPagar">S/ 0.00</strong></div>
                                                </div>
                                                <div class="row mb-2">
                                                    <div class="col-6"><strong>Por Facturar:</strong></div>
                                                    <div class="col-6 text-end"><strong id="totalPorFacturar">S/ 0.00</strong></div>
                                                </div>
                                                <div class="row mb-2">
                                                    <div class="col-6">Abono:</div>
                                                    <div class="col-6">
                                                        <input type="number" step="0.01" min="0" class="form-control form-control-sm" id="abono" placeholder="0.00" value="0">
                                                    </div>
                                                </div>
                                                <hr>
                                                <div class="row">
                                                    <div class="col-6"><strong>Saldo:</strong></div>
                                                    <div class="col-6 text-end"><strong id="saldo">S/ 0.00</strong></div>
                                                </div>
                                                <div class="mt-3">
                                                    <button type="button" class="btn btn-success w-100" id="btnGuardarCotizacion">
                                                        <i class="fas fa-save"></i> Guardar Cotización
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Lista de Cotizaciones -->
            <div class="tab-pane fade" id="lista-cotizaciones" role="tabpanel">
                <div class="row mt-4">
                    <div class="col-12">
                        <div class="card">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5>Lista de Cotizaciones</h5>
                                <button class="btn btn-primary btn-sm" onclick="cargarCotizaciones()">
                                    <i class="fas fa-sync"></i> Actualizar
                                </button>
                            </div>
                            <div class="card-body">
                                <div class="row mb-3">
                                    <div class="col-md-4">
                                        <input type="text" class="form-control" id="buscarCotizacion" placeholder="Buscar por cliente...">
                                    </div>
                                    <div class="col-md-3">
                                        <select class="form-select" id="filtroEstado">
                                            <option value="">Todos los estados</option>
                                            <option value="pendiente">Pendiente</option>
                                            <option value="pagado">Pagado</option>
                                            <option value="cancelado">Cancelado</option>
                                        </select>
                                    </div>
                                </div>
                                
                                <div class="table-responsive">
                                    <table class="table table-hover">
                                        <thead class="table-light">
                                            <tr>
                                                <th>ID</th>
                                                <th>Cliente</th>
                                                <th>Total</th>
                                                <th>Abono</th>
                                                <th>Saldo</th>
                                                <th>Estado</th>
                                                <th>Fecha</th>
                                                <th>Acciones</th>
                                            </tr>
                                        </thead>
                                        <tbody id="tablaCotizaciones">
                                            <tr id="noCotizaciones">
                                                <td colspan="8" class="text-center text-muted">No hay cotizaciones registradas</td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Productos -->
            <div class="tab-pane fade" id="productos" role="tabpanel">
                <div class="row mt-4">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <h5 id="tituloFormProducto">Agregar Producto</h5>
                            </div>
                            <div class="card-body">
                                <form id="formProducto">
                                    <input type="hidden" id="productoId" name="id">
                                    <div class="mb-3">
                                        <label for="nombreProducto" class="form-label">Nombre</label>
                                        <input type="text" class="form-control" id="nombreProducto" name="nombre" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="precioProducto" class="form-label">Precio</label>
                                        <input type="number" step="0.01" class="form-control" id="precioProducto" name="precio" required>
                                    </div>
                                    <button type="submit" class="btn btn-primary" id="btnProducto">Agregar Producto</button>
                                    <button type="button" class="btn btn-secondary" id="btnCancelarProducto" style="display:none;">Cancelar</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <h5>Lista de Productos</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <input type="text" class="form-control" id="buscarProducto" placeholder="Buscar productos...">
                                </div>
                                <div id="listaProductos"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Tab Clientes -->
            <div class="tab-pane fade" id="clientes" role="tabpanel">
                <div class="row mt-4">
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <h5 id="tituloFormCliente">Agregar Cliente</h5>
                            </div>
                            <div class="card-body">
                                <form id="formCliente">
                                    <input type="hidden" id="clienteId" name="id">
                                    <div class="mb-3">
                                        <label for="razonSocial" class="form-label">Razón Social</label>
                                        <input type="text" class="form-control" id="razonSocial" name="razon_social" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="dniRuc" class="form-label">DNI/RUC</label>
                                        <input type="text" class="form-control" id="dniRuc" name="dni_ruc" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="distrito" class="form-label">Distrito</label>
                                        <input type="text" class="form-control" id="distrito" name="distrito" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="direccion" class="form-label">Dirección</label>
                                        <input type="text" class="form-control" id="direccion" name="direccion" required>
                                    </div>
                                    <div class="mb-3">
                                        <label for="telefono" class="form-label">Teléfono</label>
                                        <input type="text" class="form-control" id="telefono" name="telefono" required>
                                    </div>
                                    <button type="submit" class="btn btn-primary" id="btnCliente">Agregar Cliente</button>
                                    <button type="button" class="btn btn-secondary" id="btnCancelarCliente" style="display:none;">Cancelar</button>
                                </form>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="card">
                            <div class="card-header">
                                <h5>Lista de Clientes</h5>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <input type="text" class="form-control" id="buscarCliente" placeholder="Buscar clientes...">
                                </div>
                                <div id="listaClientes"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/admin.js"></script>
</body>
</html>