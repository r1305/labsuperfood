<%
function formatearMonedaPDF(monto) {
    const numero = parseFloat(monto) || 0;
    return numero.toLocaleString('es-PE', {
        style: 'currency',
        currency: 'PEN',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
}

function formatearNumeroPDF(monto) {
    const numero = parseFloat(monto) || 0;
    return numero.toLocaleString('es-PE', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
}

function formatearFechaLimaPDF(fechaStr) {
    return new Date(fechaStr).toLocaleString('es-PE', {
        timeZone: 'America/Lima',
        day: '2-digit', month: '2-digit', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
    });
}
%>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cotización #<%= cotizacion.id %></title>
    <style>
        @page {
            margin-top: 10mm;
            margin-left: 10mm;
            margin-right: 10mm;
            margin-bottom: 10mm;
        }
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 15px;
            color: #333;
            font-size: 10px;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #007bff;
            padding-bottom: 15px;
        }
        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #007bff;
            margin-bottom: 3px;
        }
        .document-title {
            font-size: 18px;
            margin: 8px 0;
        }
        .cotizacion-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .cliente-info, .cotizacion-details {
            width: 48%;
        }
        .info-box {
            border: 1px solid #ddd;
            padding: 10px;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .info-title {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 8px;
            color: #007bff;
        }
        .info-line {
            margin-bottom: 3px;
            font-size: 10px;
        }
        .productos-table {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
            table-layout: fixed;
        }
        .productos-table th,
        .productos-table td {
            border: 1px solid #ddd;
            padding: 4px;
            text-align: left;
            font-size: 9px;
            white-space: normal;
            word-wrap: break-word;
            vertical-align: middle;
            line-height: 1.1;
        }
        
        /* Centrado específico para columnas numéricas */
        .productos-table th:nth-child(n+2),
        .productos-table td:nth-child(n+2) {
            text-align: center;
            vertical-align: middle;
        }
        .productos-table th {
            background-color: #007bff;
            color: white;
            font-weight: bold;
        }
        .productos-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        .text-right {
            text-align: right;
        }
        .text-center {
            text-align: center;
        }
        .totales {
            margin-top: 15px;
            float: right;
            width: 280px;
        }
        .totales-table {
            width: 100%;
            border-collapse: collapse;
        }
        .totales-table td {
            padding: 4px;
            border-bottom: 1px solid #ddd;
            font-size: 10px;
        }
        .totales-table .total-row {
            font-weight: bold;
            font-size: 12px;
            background-color: #007bff;
            color: white;
        }
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            width: 100%;
            clear: both;
            padding: 12px 15px;
            background-color: white;
            box-sizing: border-box;
            border-top: 2px solid #007bff;
            -webkit-print-color-adjust: exact;
            print-color-adjust: exact;
        }
        .main-content {
            margin-bottom: 160px;
        }
        .deposito-titulo {
            color: #007bff;
            font-size: 13px;
            font-weight: bold;
            margin-bottom: 8px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .deposito-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        .deposito-card {
            flex: 1;
            min-width: 180px;
            border: 1px solid #007bff;
            border-radius: 5px;
            padding: 8px 10px;
            background-color: #f0f7ff;
        }
        .deposito-banco {
            font-size: 13px;
            font-weight: bold;
            color: #007bff;
            margin-bottom: 4px;
        }
        .deposito-tipo {
            background-color: #17a2b8;
            color: white;
            padding: 1px 5px;
            border-radius: 3px;
            font-size: 10px;
            margin-left: 5px;
            vertical-align: middle;
        }
        .deposito-fila {
            font-size: 12px;
            margin-bottom: 3px;
            color: #333;
        }
        .deposito-fila span {
            color: #666;
        }
        .estado-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .estado-pendiente {
            background-color: #ffc107;
            color: #212529;
        }
        .estado-pagado {
            background-color: #28a745;
            color: white;
        }
        .estado-cancelado {
            background-color: #dc3545;
            color: white;
        }
    </style>
</head>
<body>
    <div class="main-content">
    <div class="header">
        <div class="company-name"><%= cotizacion.company_nombre %></div>
        <div style="font-size: 12px; color: #666; margin-bottom: 3px;">RUC <%= cotizacion.company_ruc %></div>
        <div class="document-title">COTIZACIÓN</div>
        <div>N° <%= cotizacion.id.toString().padStart(6, '0') %></div>
        <div style="font-size: 11px; color: #666; margin-top: 4px;"><%= formatearFechaLimaPDF(cotizacion.created_at) %></div>
    </div>

    <div class="cotizacion-info">
        <div class="cliente-info">
            <div class="info-box">
                <div class="info-title">DATOS DEL CLIENTE</div>
                <div class="info-line"><strong>Razón Social:</strong> <%= cotizacion.razon_social %></div>
                <div class="info-line"><strong>DNI/RUC:</strong> <%= cotizacion.dni_ruc %></div>
                <div class="info-line"><strong>Distrito/Provincia:</strong> <%= cotizacion.distrito %></div>
                <div class="info-line"><strong>Dirección:</strong> <%= cotizacion.direccion %></div>
                <div class="info-line"><strong>Teléfono:</strong> <%= cotizacion.telefono %></div>
                <% if (cotizacion.correo) { %>
                <div class="info-line"><strong>Correo:</strong> <%= cotizacion.correo %></div>
                <% } %>
            </div>
        </div>
        

    </div>

    <table class="productos-table">
        <thead>
            <tr>
                <th style="width: 35%;">PRODUCTO</th>
                <th style="width: 13%; text-align: center;">CANTIDAD</th>
                <th style="width: 13%; text-align: center;">PRECIO UNIT.</th>
                <th style="width: 13%; text-align: center;">TOTAL</th>
                <th style="width: 13%; text-align: center;">POR FACTURAR</th>
            </tr>
        </thead>
        <tbody>
            <% detalles.forEach(detalle => { %>
            <tr>
                <td style="width: 35%; line-height: 1.1; max-height: 2.2em; overflow: hidden; vertical-align: middle;"><%= detalle.producto_nombre %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= parseInt(detalle.cantidad) %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearMonedaPDF(detalle.precio_unitario) %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearMonedaPDF(detalle.total) %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearMonedaPDF(detalle.total) %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="totales">
        <table class="totales-table">
            <tr>
                <td><strong>SUBTOTAL:</strong></td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.total) %></td>
            </tr>
            <tr>
                <td><strong>POR FACTURAR:</strong></td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.total) %></td>
            </tr>
            <tr>
                <td>ABONO:</td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.abono) %></td>
            </tr>
            <tr class="total-row">
                <td>SALDO:</td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.saldo) %></td>
            </tr>
        </table>
    </div>



    </div>

    <div class="footer">
        <% if (typeof cuentasBancarias !== 'undefined' && cuentasBancarias.length > 0) { %>
        <div class="deposito-titulo">&#128176; Información para Depósito</div>
        <div class="deposito-grid">
            <% cuentasBancarias.forEach(cuenta => { %>
            <div class="deposito-card">
                <div class="deposito-banco">
                    <%= cuenta.banco %>
                    <span class="deposito-tipo"><%= cuenta.tipo_cuenta === 'ahorros' ? 'AHORROS' : 'CORRIENTE' %></span>
                </div>
                <div class="deposito-fila"><span>Número de Cuenta:</span> <strong><%= cuenta.numero_cuenta %></strong></div>
                <% if (cuenta.cci) { %>
                <div class="deposito-fila"><span>CCI:</span> <strong><%= cuenta.cci %></strong></div>
                <% } %>
                <div class="deposito-fila"><span>Titular:</span> <strong><%= cuenta.titular %></strong></div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>
</body>
</html>