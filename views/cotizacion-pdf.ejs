<%
// Función para formatear moneda peruana en el template
function formatearMonedaPDF(monto) {
    const numero = parseFloat(monto) || 0;
    return numero.toLocaleString('es-PE', {
        style: 'currency',
        currency: 'PEN',
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
}

function formatearNumeroPDF(monto) {
    const numero = parseFloat(monto) || 0;
    return numero.toLocaleString('es-PE', {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2
    });
}
%>
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cotización #<%= cotizacion.id %></title>
    <style>
        @page {
            margin: 10mm; /* Márgenes de página reducidos a la mitad */
        }
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 15px;
            color: #333;
            font-size: 10px;
        }
        .header {
            text-align: center;
            margin-bottom: 20px;
            border-bottom: 2px solid #007bff;
            padding-bottom: 15px;
        }
        .company-name {
            font-size: 22px;
            font-weight: bold;
            color: #007bff;
            margin-bottom: 3px;
        }
        .document-title {
            font-size: 18px;
            margin: 8px 0;
        }
        .cotizacion-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 20px;
        }
        .cliente-info, .cotizacion-details {
            width: 48%;
        }
        .info-box {
            border: 1px solid #ddd;
            padding: 10px;
            border-radius: 5px;
            background-color: #f9f9f9;
        }
        .info-title {
            font-weight: bold;
            font-size: 12px;
            margin-bottom: 8px;
            color: #007bff;
        }
        .info-line {
            margin-bottom: 3px;
            font-size: 10px;
        }
        .productos-table {
            width: 100%;
            border-collapse: collapse;
            margin: 15px 0;
            table-layout: fixed;
        }
        .productos-table th,
        .productos-table td {
            border: 1px solid #ddd;
            padding: 4px;
            text-align: left;
            font-size: 9px;
            white-space: normal;
            word-wrap: break-word;
            vertical-align: middle;
            line-height: 1.1;
        }
        
        /* Centrado específico para columnas numéricas */
        .productos-table th:nth-child(n+2),
        .productos-table td:nth-child(n+2) {
            text-align: center;
            vertical-align: middle;
        }
        .productos-table th {
            background-color: #007bff;
            color: white;
            font-weight: bold;
        }
        .productos-table tr:nth-child(even) {
            background-color: #f9f9f9;
        }
        .text-right {
            text-align: right;
        }
        .text-center {
            text-align: center;
        }
        .totales {
            margin-top: 15px;
            float: right;
            width: 280px;
        }
        .totales-table {
            width: 100%;
            border-collapse: collapse;
        }
        .totales-table td {
            padding: 4px;
            border-bottom: 1px solid #ddd;
            font-size: 10px;
        }
        .totales-table .total-row {
            font-weight: bold;
            font-size: 12px;
            background-color: #007bff;
            color: white;
        }
        .footer {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            width: 100%;
            text-align: center;
            font-size: 8px;
            color: #666;
            clear: both;
            padding: 10px 20px;
            background-color: white;
            box-sizing: border-box;
        }
        .main-content {
            margin-bottom: 180px;
        }
        .estado-badge {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 12px;
            font-weight: bold;
            text-transform: uppercase;
        }
        .estado-pendiente {
            background-color: #ffc107;
            color: #212529;
        }
        .estado-pagado {
            background-color: #28a745;
            color: white;
        }
        .estado-cancelado {
            background-color: #dc3545;
            color: white;
        }
    </style>
</head>
<body>
    <div class="main-content">
    <div class="header">
        <div class="company-name">Maquila Lima Lab</div>
        <div style="font-size: 12px; color: #666; margin-bottom: 3px;">RUC 20607583677</div>
        <div class="document-title">COTIZACIÓN</div>
        <div>N° <%= cotizacion.id.toString().padStart(6, '0') %></div>
    </div>

    <div class="cotizacion-info">
        <div class="cliente-info">
            <div class="info-box">
                <div class="info-title">DATOS DEL CLIENTE</div>
                <div class="info-line"><strong>Razón Social:</strong> <%= cotizacion.razon_social %></div>
                <div class="info-line"><strong>DNI/RUC:</strong> <%= cotizacion.dni_ruc %></div>
                <div class="info-line"><strong>Distrito:</strong> <%= cotizacion.distrito %></div>
                <div class="info-line"><strong>Dirección:</strong> <%= cotizacion.direccion %></div>
                <div class="info-line"><strong>Teléfono:</strong> <%= cotizacion.telefono %></div>
            </div>
        </div>
        
        <div class="cotizacion-details">
            <div class="info-box">
                <div class="info-title">INFORMACIÓN DE LA COTIZACIÓN</div>
                <div class="info-line"><strong>Fecha:</strong> <%= new Date(cotizacion.created_at).toLocaleDateString('es-PE') %></div>
                <div class="info-line"><strong>Hora:</strong> <%= new Date(cotizacion.created_at).toLocaleTimeString('es-PE') %></div>
                <div class="info-line">
                    <strong>Estado:</strong> 
                    <span class="estado-badge estado-<%= cotizacion.estado %>">
                        <%= cotizacion.estado %>
                    </span>
                </div>
            </div>
        </div>
    </div>

    <table class="productos-table">
        <thead>
            <tr>
                <th style="width: 35%;">PRODUCTO</th>
                <th style="width: 13%; text-align: center;">CANTIDAD</th>
                <th style="width: 13%; text-align: center;">PRECIO UNIT.</th>
                <th style="width: 13%; text-align: center;">TOTAL</th>
                <th style="width: 13%; text-align: center;">POR FACTURAR</th>
            </tr>
        </thead>
        <tbody>
            <% detalles.forEach(detalle => { %>
            <tr>
                <td style="width: 35%; line-height: 1.1; max-height: 2.2em; overflow: hidden; vertical-align: middle;"><%= detalle.producto_nombre %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearNumeroPDF(detalle.cantidad) %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearMonedaPDF(detalle.precio_unitario) %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearMonedaPDF(detalle.total) %></td>
                <td style="width: 13%; text-align: center; vertical-align: middle;"><%= formatearMonedaPDF(detalle.total) %></td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <div class="totales">
        <table class="totales-table">
            <tr>
                <td><strong>SUBTOTAL:</strong></td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.total) %></td>
            </tr>
            <tr>
                <td><strong>POR FACTURAR:</strong></td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.total) %></td>
            </tr>
            <tr>
                <td>ABONO:</td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.abono) %></td>
            </tr>
            <tr class="total-row">
                <td>SALDO:</td>
                <td class="text-right"><%= formatearMonedaPDF(cotizacion.saldo) %></td>
            </tr>
        </table>
    </div>



    </div>

    <div class="footer">
        <!-- Información Bancaria -->
        <% 
        // Obtener cuentas bancarias activas (esto se pasará desde el servidor)
        if (typeof cuentasBancarias !== 'undefined' && cuentasBancarias.length > 0) {
        %>
        <div style="margin-bottom: 10px; page-break-inside: avoid; text-align: left;">
            <h6 style="color: #007bff; margin-bottom: 8px; font-size: 11px; text-align: left;">INFORMACIÓN PARA DEPÓSITO</h6>
            <% cuentasBancarias.forEach(cuenta => { %>
            <div style="border: 1px solid #ddd; border-radius: 3px; padding: 6px; margin-bottom: 6px; background-color: #f9f9f9; display: inline-block; width: 48%; margin-right: 1%; vertical-align: top;">
                <div style="margin-bottom: 3px;">
                    <strong style="color: #007bff; font-size: 9px;"><%= cuenta.banco %></strong>
                    <span style="background-color: #17a2b8; color: white; padding: 1px 3px; border-radius: 2px; font-size: 7px; margin-left: 5px;">
                        <%= cuenta.tipo_cuenta === 'ahorros' ? 'AHORROS' : 'CORRIENTE' %>
                    </span>
                </div>
                <div style="font-size: 8px; margin-bottom: 1px;">
                    <span style="color: #666;">Número de Cuenta:</span> <strong><%= cuenta.numero_cuenta %></strong>
                </div>
                <% if (cuenta.cci) { %>
                <div style="font-size: 8px; margin-bottom: 1px;">
                    <span style="color: #666;">CCI:</span> <strong><%= cuenta.cci %></strong>
                </div>
                <% } %>
                <div style="font-size: 8px;">
                    <span style="color: #666;">Titular:</span> <strong><%= cuenta.titular %></strong>
                </div>
            </div>
            <% }); %>
        </div>
        <% } %>
    </div>
</body>
</html>